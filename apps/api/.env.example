# =============================================================================
# PokeGrind API — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# Application
NODE_ENV=development
PORT=3333
APP_NAME=PokeGrind
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# =============================================================================
# Base de données PostgreSQL
# =============================================================================
DATABASE_URL=postgresql://pokegrind:dev_password_change_in_prod@localhost:5432/pokegrind

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Authentification JWT
# Générer avec : openssl rand -hex 32
# =============================================================================
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# =============================================================================
# Discord OAuth — https://discord.com/developers/applications
# =============================================================================
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# =============================================================================
# Web Push (VAPID) — Sprint 5
# Générer avec : node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))"
# Ou : npx web-push generate-vapid-keys
# Les clés VAPID sont fixes pour un déploiement donné — ne pas regénérer en prod
# =============================================================================
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@pokegrind.fr

# =============================================================================
# URLs frontends (utilisé pour CORS)
# =============================================================================
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
