# PokeGrind API — Variables d'environnement production
# Copier ce fichier en .env.prod et remplir les valeurs

# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pokegrind:CHANGE_ME@postgres:5432/pokegrind

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
APP_KEY=CHANGE_ME
JWT_SECRET=CHANGE_ME

# ── Discord OAuth ─────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=CHANGE_ME
DISCORD_CLIENT_SECRET=CHANGE_ME
DISCORD_CALLBACK_URL=https://pokegrind.fr/auth/discord/callback

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:admin@pokegrind.fr

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3333
FRONTEND_URL=https://pokegrind.fr
ADMIN_URL=https://admin.pokegrind.fr
